{
	"name": "textmode.filters.js",
	"version": "1.1.1",
	"description": "Image filters plugin for textmode.js",
	"type": "module",
	"main": "./dist/textmode.filters.umd.js",
	"module": "./dist/textmode.filters.esm.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.filters.esm.js",
			"require": "./dist/textmode.filters.umd.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --port 5179 --host",
		"build:bundle": "vite build",
		"build:types": "tsc -p tsconfig.json",
		"build": "npm run build:bundle && npm run build:types",
		"check": "npm run check:format && npm run lint && npm run lint:md && npm run check:types && npm run build",
		"dev:docs": "typedoc --watch",
		"build:docs": "typedoc",
		"preview": "vite preview",
		"format": "prettier --write .",
		"check:format": "prettier --check .",
		"check:types": "tsc --noEmit -p tsconfig.json",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"lint": "eslint src --config eslint.config.js",
		"prepare": "husky"
	},
	"peerDependencies": {
		"textmode.js": ">=0.7.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.4",
		"@mapwhit/glsl-minify": "^1.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/exec": "^7.1.0",
		"@types/node": "^24.0.13",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.9.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.1",
		"markdownlint-cli2-formatter-default": "^0.0.6",
		"prettier": "^3.8.3",
		"semantic-release": "^25.0.3",
		"textmode.js": "^0.12.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.59.0",
		"vite": "^6.3.4"
	},
	"license": "MIT",
	"author": "humanbydefinition",
	"lint-staged": {
		"**/*.{ts,js,json,jsonc,html,css}": "prettier --write",
		".*.{js,json,jsonc}": "prettier --write"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/humanbydefinition/textmode.filters.js"
	}
}
