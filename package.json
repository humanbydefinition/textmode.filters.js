{
	"name": "textmode.filters.js",
	"version": "1.1.1",
	"description": "Image filters plugin for textmode.js",
	"type": "module",
	"main": "./dist/textmode.filters.umd.js",
	"module": "./dist/textmode.filters.esm.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.filters.esm.js",
			"require": "./dist/textmode.filters.umd.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --port 5179 --host",
		"build": "vite build && tsc -p tsconfig.json",
		"check": "npm run format:check && npm run lint && npm run lint:md && npm run typecheck && npm run build",
		"dev:docs": "typedoc --watch",
		"build:docs": "typedoc",
		"preview": "vite preview",
		"format": "prettier --write \"src/**/*.{ts,js}\" \"vite-plugins/**/*.ts\" \"typedoc-plugins/**/*.js\" \"examples/**/*.{js,html,css}\" \"*.{js,ts,json}\" \".markdownlint*.jsonc\" \".prettierrc\" \".releaserc.json\"",
		"format:check": "prettier --check \"src/**/*.{ts,js}\" \"vite-plugins/**/*.ts\" \"typedoc-plugins/**/*.js\" \"examples/**/*.{js,html,css}\" \"*.{js,ts,json}\" \".markdownlint*.jsonc\" \".prettierrc\" \".releaserc.json\"",
		"typecheck": "tsc --noEmit",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"lint": "eslint src --config eslint.config.js",
		"prepare": "husky"
	},
	"peerDependencies": {
		"textmode.js": ">=0.7.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@eslint/js": "^9.39.4",
		"@mapwhit/glsl-minify": "^1.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/github": "^11.0.6",
		"@semantic-release/npm": "^12.0.2",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^24.0.13",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.4.1",
		"globals": "^17.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.20.0",
		"markdownlint-cli2-formatter-default": "^0.0.6",
		"prettier": "^3.7.4",
		"semantic-release": "^24.2.9",
		"textmode.js": ">=0.7.0",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.13",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.9.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.53.1",
		"vite": "^6.3.4"
	},
	"license": "MIT",
	"author": "humanbydefinition",
	"lint-staged": {
		"**/*.{ts,js,json,jsonc,html,css}": "prettier --write",
		".*.{js,json,jsonc}": "prettier --write"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/humanbydefinition/textmode.filters.js"
	}
}
